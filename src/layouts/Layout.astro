---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Morning Brief — Save it now. Hear it in the morning.",
  description = "Save the articles you didn't get to today. Tomorrow morning, wake up to an AI-summarised podcast covering them — ready before your coffee.",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Morning Brief" />
    <meta
      property="og:description"
      content="Save links during the day. Wake up to an AI-summarised podcast covering them."
    />
    <meta property="og:url" content={canonical} />
    <meta name="theme-color" content="#fff4ea" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body class="min-h-dvh bg-surface font-sans text-ink-1 subpixel-antialiased">
    <slot />
  </body>
</html>
