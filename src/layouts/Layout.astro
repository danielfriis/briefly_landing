---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Recap — Today's news, recapped tomorrow.",
  description = "Follow the topics you care about. Tomorrow morning, wake up to an AI-summarised podcast covering them — plus any links you saved, ready before your coffee.",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
// Absolute URL — social platforms require a fully-qualified og:image.
const ogImage = new URL("/og.png", Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Recap" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="Recap — today's news, recapped tomorrow."
    />

    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#fdfcfb" />

    <link rel="icon" href="/logo.svg" type="image/svg+xml" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body class="min-h-dvh bg-surface font-sans text-ink-1 subpixel-antialiased">
    <slot />
  </body>
</html>
