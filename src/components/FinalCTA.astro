---
import { site } from "../config";
---

<section class="mx-auto w-full max-w-5xl px-4 sm:px-6">
  <div class="relative overflow-hidden rounded-3xl border border-line bg-elevated px-6 py-16 text-center shadow-card sm:px-12 sm:py-20">
    <div class="hero-glow pointer-events-none absolute inset-x-0 -top-16 h-64" aria-hidden="true"></div>
    <div class="relative mx-auto flex max-w-2xl flex-col items-center gap-6">
      <h2 class="font-display text-4xl font-medium tracking-tight text-balance text-ink-1 sm:text-5xl">
        Put down the feed.<br />Press play tomorrow morning.
      </h2>
      <p class="max-w-xl text-lg text-pretty text-ink-3">
        Choose the topics you're curious about tonight. Wake up to one short,
        calm briefing — and let the endless feed scroll on without you.
      </p>
      <div class="mt-2 flex flex-col items-center gap-3">
        <a
          href={site.signUp}
          class="inline-flex h-12 select-none items-center justify-center gap-1.5 rounded-full bg-palette-800 px-7 text-[15px] font-medium text-palette-50 shadow-sm transition-colors hover:bg-palette-700"
          >Start for free</a
        >
        <p class="text-[13px] text-ink-3">
          Free during beta · no card needed to hear your first briefing
        </p>
      </div>
    </div>
  </div>
</section>
