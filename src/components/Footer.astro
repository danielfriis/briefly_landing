---
// Quiet, centered footer — shares the page background, no band or heavy link
// grid. Just the mark, the tagline, and the essentials.
import { site } from "../config";
import Brand from "./Brand.astro";
const year = new Date().getFullYear();
---

<footer class="bg-surface text-ink-1">
  <div
    class="mx-auto flex w-full max-w-2xl flex-col items-center gap-5 px-5 pt-24 pb-16 text-center sm:pt-32"
  >
    <Brand />
    <p class="font-display text-lg text-ink-3">Put down the feed. Press play.</p>
    <div class="flex items-center gap-5 text-sm text-ink-2">
      <a href={site.signUp} class="transition-colors hover:text-ink-1">Start for free</a>
      <a href={site.signIn} class="transition-colors hover:text-ink-1">Sign in</a>
    </div>
    <p class="text-sm text-ink-4">© {year} {site.name}</p>
  </div>
</footer>
