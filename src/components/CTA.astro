---
import { site } from "../config";
---

<section id="pricing" class="mx-auto flex w-full max-w-2xl flex-col gap-8 px-4 py-8 sm:py-12">
  <div class="flex flex-col">
    <h2 class="text-2xl font-medium text-ink-1">Pricing</h2>
    <h3 class="text-2xl font-medium text-ink-4">Try it free for 7 days, then $9/month.</h3>
  </div>

  <div class="flex flex-col gap-2 rounded-xl border p-6">
    <div class="flex flex-col gap-1">
      <p class="text-3xl font-medium text-ink-1">Free during beta</p>
      <div class="flex items-baseline gap-0.5 text-ink-4 line-through">
        <p class="text-3xl font-medium">$9</p>
        <p class="text-2xl font-medium">/mo</p>
      </div>
    </div>
    <p class="max-w-md text-lg text-balance text-ink-2">
      Follow unlimited topics, save your own links, and get a daily briefing in your private podcast feed.
      Start with a 7-day free trial — no card needed to listen to your first briefing.
    </p>
    <ul class="mt-6 mb-6 flex flex-1 flex-col gap-2 text-base text-ink-3">
      {
        [
          "Follow unlimited topics, researched on the live web",
          "Daily AI-summarised podcast briefing",
          "Save your own article links to any briefing",
          "Private feed for any podcast app",
          "Generate a briefing on demand",
        ].map((f) => (
          <li class="flex items-center gap-1.5">
            <svg width="22" height="22" viewBox="0 0 24 24" class="shrink-0 text-ink-3" fill="none">
              <path d="m7 13 3 3c1.5-5.5 6-9 6-9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <span>{f}</span>
          </li>
        ))
      }
    </ul>
    <a
      href={site.signUp}
      class="inline-flex h-10 select-none items-center justify-center gap-1.5 self-start rounded-lg bg-palette-800 px-4 text-sm font-medium text-palette-50 shadow-lg transition-colors hover:bg-palette-700"
      >Start 7-day free trial</a
    >
  </div>
</section>
