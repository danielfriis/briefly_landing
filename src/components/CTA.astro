---
import { site } from "../config";
---

<section class="py-24 text-center">
  <div class="mx-auto max-w-6xl px-6">
    <h2 class="text-[clamp(1.875rem,4.5vw,2.75rem)] font-bold tracking-tight">
      Wake up to your reading.
    </h2>
    <p class="mt-3 mb-7 text-lg text-stone-600">
      Save a few links tonight. Hear them tomorrow morning.
    </p>
    <a
      href={site.signUp}
      class="inline-flex items-center justify-center rounded-xl bg-stone-900 px-6 py-3.5 text-base font-semibold text-white transition hover:bg-stone-700"
      >Start your brief</a
    >
  </div>
</section>
