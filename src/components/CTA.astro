---
import { site } from "../config";
---

<section class="mx-auto max-w-5xl px-6 py-24 md:py-32">
  <div
    class="relative overflow-hidden rounded-3xl bg-neutral-900 px-6 py-16 text-center text-white"
  >
    <div class="dotgrid pointer-events-none absolute inset-0 opacity-[0.06]"></div>
    <div class="relative">
      <div class="mb-4 text-4xl" aria-hidden="true">{site.mark}</div>
      <h2 class="text-[clamp(1.875rem,4.5vw,2.75rem)] font-semibold tracking-[-0.02em]">
        Wake up to your reading.
      </h2>
      <p class="mx-auto mt-3 max-w-md text-lg text-neutral-300">
        Save a few links tonight. Hear them tomorrow morning.
      </p>
      <a
        href={site.signUp}
        class="mt-8 inline-flex items-center justify-center rounded-full bg-white px-6 py-3 text-[15px] font-medium text-neutral-900 transition hover:bg-neutral-200"
        >Start your brief</a
      >
    </div>
  </div>
</section>
