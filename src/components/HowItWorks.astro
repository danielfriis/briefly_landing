---
const steps = [
  {
    n: "1",
    title: "Save links",
    body: "Paste any article URL into your queue during the day — from your phone or laptop.",
  },
  {
    n: "2",
    title: "We brew it",
    body: "Overnight, AI reads each article and writes a tight radio script, then renders it to audio.",
  },
  {
    n: "3",
    title: "Press play",
    body: "A single brief is waiting at your chosen hour — in the app or your favourite podcast player.",
  },
];
---

<section id="how" class="py-20 md:py-24">
  <div class="mx-auto max-w-6xl px-6">
    <h2
      class="text-center text-[clamp(1.75rem,4vw,2.375rem)] font-bold tracking-tight"
    >
      How it works
    </h2>
    <p class="mx-auto mt-2.5 mb-12 max-w-[36em] text-center text-lg text-stone-500">
      Three steps. No new habits to build.
    </p>

    <div class="grid gap-6 md:grid-cols-3">
      {
        steps.map((s) => (
          <div class="rounded-2xl border border-stone-200 bg-stone-50 p-7">
            <div class="mb-4 grid size-9 place-items-center rounded-[10px] bg-stone-900 font-bold text-white">
              {s.n}
            </div>
            <h3 class="mb-2 text-[19px] font-semibold tracking-tight">
              {s.title}
            </h3>
            <p class="text-stone-600">{s.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
