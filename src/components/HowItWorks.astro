---
const steps = [
  {
    n: "01",
    title: "Save links",
    body: "Paste any article URL into your queue during the day — from your phone or laptop.",
  },
  {
    n: "02",
    title: "We brew it",
    body: "Overnight, AI reads each article and writes a tight radio script, then renders it to audio.",
  },
  {
    n: "03",
    title: "Press play",
    body: "A single brief is waiting at your chosen hour — in the app or your favourite podcast player.",
  },
];
---

<section id="how" class="mx-auto max-w-5xl px-6 py-20 md:py-28">
  <div class="mb-12 text-center">
    <h2 class="text-[clamp(1.75rem,4vw,2.5rem)] font-semibold tracking-[-0.02em]">
      How it works
    </h2>
    <p class="mx-auto mt-3 max-w-md text-lg text-neutral-500">
      Three steps. No new habits to build.
    </p>
  </div>

  <div class="grid gap-px overflow-hidden rounded-2xl border border-neutral-200 bg-neutral-200 md:grid-cols-3">
    {
      steps.map((s) => (
        <div class="bg-white p-7">
          <div class="mb-4 text-[13px] font-semibold tabular-nums text-neutral-300">
            {s.n}
          </div>
          <h3 class="mb-2 text-lg font-semibold tracking-tight">{s.title}</h3>
          <p class="text-[15px] text-neutral-500">{s.body}</p>
        </div>
      ))
    }
  </div>
</section>
