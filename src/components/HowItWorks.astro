---
const steps = [
  {
    title: "Follow your curiosities",
    body: "Pick presets like World news or Technology, or follow anything you're curious about — researched fresh on the live web.",
    icon: "globe",
  },
  {
    title: "We brew it overnight",
    body: "AI reads across your topics, keeps only what's worth knowing, and writes it into a tight radio script in a natural voice.",
    icon: "sun",
  },
  {
    title: "Save links too",
    body: "Got an article you want covered? Drop any URL into your next briefing — it rides along on top of your topics.",
    icon: "plus",
  },
  {
    title: "On your schedule",
    body: "Set your local hour and timezone. Your briefing lands right when you want it.",
    icon: "clock",
  },
  {
    title: "Your private podcast",
    body: "Add the private feed to Apple Podcasts, Overcast, or Pocket Casts. New briefings appear automatically.",
    icon: "rss",
  },
  {
    title: "Yours alone",
    body: "Your topics and feed are private, secured by a secret link you can rotate any time.",
    icon: "lock",
  },
];
---

<section id="how" class="mx-auto flex w-full max-w-2xl flex-col gap-10 px-4 py-8 sm:gap-16 sm:py-12">
  <div class="flex flex-col gap-1">
    <h2 class="max-w-md text-2xl font-medium text-balance text-ink-1">
      The whole noisy world, narrowed down to you.
    </h2>
    <h3 class="text-2xl font-medium text-balance text-ink-4">
      Choose what you're curious about. Briefing reads the web so you don't have to, leaves out the noise, and delivers a single podcast each morning — plus any links you saved.
    </h3>
  </div>

  <div class="grid grid-cols-1 gap-x-8 gap-y-10 sm:grid-cols-2 sm:gap-y-16">
    {
      steps.map((s) => (
        <div class="flex flex-col gap-4">
          <div class="flex size-8 flex-none items-center justify-center text-ink-2">
            {s.icon === "plus" && (
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none">
                <path stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M12 5.75V18.25M5.75 12H18.25" />
              </svg>
            )}
            {s.icon === "sun" && (
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="13" r="3.25" stroke="currentColor" stroke-width="1.5" />
                <path stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M12 4.75V6.25M5.75 8L6.75 9M18.25 8L17.25 9M4.75 16.25H19.25" />
              </svg>
            )}
            {s.icon === "globe" && (
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="7.25" stroke="currentColor" stroke-width="1.5" />
                <path stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M4.75 12H19.25" />
                <path stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M12 4.75C13.9 6.8 14.75 9.3 14.75 12C14.75 14.7 13.9 17.2 12 19.25C10.1 17.2 9.25 14.7 9.25 12C9.25 9.3 10.1 6.8 12 4.75Z" />
              </svg>
            )}
            {s.icon === "clock" && (
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="7.25" stroke="currentColor" stroke-width="1.5" />
                <path stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M12 8V12L14.5 13.5" />
              </svg>
            )}
            {s.icon === "rss" && (
              <svg width="30" height="30" viewBox="0 0 24 24" fill="none">
                <path stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M5.75 5.75C12.9 5.75 18.25 11.1 18.25 18.25" />
                <path stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M5.75 11.25C9.6 11.25 12.75 14.4 12.75 18.25" />
                <circle cx="6.5" cy="17.5" r="1.25" fill="currentColor" />
              </svg>
            )}
            {s.icon === "lock" && (
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none">
                <path stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M6.75 11.75C6.75 11.1977 7.19772 10.75 7.75 10.75H16.25C16.8023 10.75 17.25 11.1977 17.25 11.75V17.25C17.25 18.3546 16.3546 19.25 15.25 19.25H8.75C7.64543 19.25 6.75 18.3546 6.75 17.25V11.75Z" />
                <path stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M8.75 10.5V8.25C8.75 6.45507 10.2051 5 12 5C13.7949 5 15.25 6.45507 15.25 8.25V10.5" />
              </svg>
            )}
          </div>
          <div class="flex flex-col">
            <h3 class="flex items-center gap-1 text-lg font-medium text-ink-1">{s.title}</h3>
            <p class="flex-none text-lg leading-[1.4] font-medium text-pretty text-ink-3 max-sm:max-w-3/4">
              {s.body}
            </p>
          </div>
        </div>
      ))
    }
  </div>
</section>
