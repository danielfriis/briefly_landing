---
const steps = [
  {
    n: "01",
    title: "Follow your curiosities",
    body: "Pick presets like World news or Technology, or follow anything you're curious about — a company, a sport, a corner of science. As many as you like.",
  },
  {
    n: "02",
    title: "We read the web overnight",
    body: "While you sleep, AI reads across your topics, keeps only what's genuinely worth knowing, and writes it into a tight radio script in a calm, natural voice.",
  },
  {
    n: "03",
    title: "Press play each morning",
    body: "Your briefing is waiting in your podcast app when you wake — one short, calm listen instead of a hundred open tabs. Then get on with your day.",
  },
];
---

<section id="how" class="mx-auto w-full max-w-6xl px-4 sm:px-6">
  <div class="flex max-w-2xl flex-col gap-3">
    <p class="text-xs font-semibold tracking-widest text-tint-700 uppercase">How it works</p>
    <h2 class="font-display text-3xl font-medium text-balance text-ink-1 sm:text-4xl">
      The whole noisy world, narrowed down to you.
    </h2>
    <p class="text-lg leading-relaxed text-pretty text-ink-3">
      Choose what you're curious about. Briefing reads the web so you don't have
      to, leaves out the noise, and delivers a single podcast each morning — plus
      any links you saved.
    </p>
  </div>

  <div class="mt-14 grid grid-cols-1 gap-10 sm:grid-cols-3 sm:gap-8">
    {
      steps.map((s, i) => (
        <div class="relative flex flex-col gap-4">
          <div class="flex items-center gap-3">
            <span class="font-display text-2xl font-medium text-tint">{s.n}</span>
            <span class="h-px flex-1 bg-line" />
          </div>
          <div class="flex flex-col gap-2">
            <h3 class="text-xl font-semibold text-ink-1">{s.title}</h3>
            <p class="text-[15px] leading-relaxed text-pretty text-ink-3">{s.body}</p>
          </div>
        </div>
      ))
    }
  </div>
</section>
