---
import { site } from "../config";

const topics = ["World news", "Technology", "Business & markets", "Formula 1"];

const stories = [
  {
    topic: "Technology",
    title: "The state of AI agents in 2026",
    source: "stratechery.com",
  },
  {
    topic: "Markets",
    title: "Why interest rates moved this week",
    source: "newsletter",
  },
  {
    topic: "World",
    title: "What the new climate accord actually changes",
    source: "reuters.com",
  },
];

const bars = Array.from({ length: 56 }, (_, i) => {
  const h = 26 + Math.round(52 * Math.abs(Math.sin(i * 1.27)));
  return { h, delay: `${((i % 7) * 0.11).toFixed(2)}s` };
});

const rotatingWords = [
  "AI",
  "the markets",
  "world politics",
  "climate",
  "Formula 1",
  "your industry",
];
---

<section class="relative overflow-hidden border-b border-line">
  <div class="relative z-10 mx-auto w-full max-w-6xl px-4 sm:px-6">
    <!-- headline block -->
    <div class="mx-auto flex max-w-3xl flex-col items-center gap-6 pt-16 pb-16 text-center sm:pt-24 sm:pb-20">
      <a
        href={site.signUp}
        class="group inline-flex items-center gap-2 rounded-full border border-line bg-elevated/70 py-1 pr-3 pl-1.5 text-[13px] font-medium text-ink-2 shadow-soft backdrop-blur transition-colors hover:border-palette-300"
      >
        <span class="inline-flex items-center gap-1 rounded-full bg-tint-50 px-2 py-0.5 text-[11px] font-semibold tracking-wide text-tint-700 uppercase">
          <span class="size-1.5 rounded-full bg-tint"></span>Beta
        </span>
        <span>Your doomscrolling, as one calm podcast</span>
      </a>

      <h1 class="font-display text-4xl font-medium tracking-tight text-pretty text-ink-1 sm:text-6xl xl:text-7xl">
        <span class="block">Put down the feed.</span>
        <span class="block">Press play on</span>
        <!-- The rotating word gets its own line: every topic fits on a single
             line at all sizes, so swapping it never wraps or reflows the page,
             and the slide animation has a clean, fixed clip height. -->
        <span class="block">
          <span class="inline-flex overflow-hidden align-bottom"
            ><span
              id="rotating-word"
              data-words={JSON.stringify(rotatingWords)}
              class="font-semibold text-tint will-change-transform"
              >{rotatingWords[0]}</span
            ></span
          >
        </span>
      </h1>

      <p class="max-w-2xl text-xl leading-relaxed text-pretty text-ink-3 sm:text-2xl">
        There's more news every day than anyone could follow. Overnight,
        briefing.fm reads the web and brings you only the headlines that
        matter, on the topics you choose, in one short podcast each morning.
      </p>

      <div class="mt-2 flex flex-col items-center gap-3">
        <div class="flex flex-wrap items-center justify-center gap-2">
          <a
            href={site.signUp}
            class="inline-flex h-12 select-none items-center justify-center gap-1.5 rounded-full bg-palette-800 px-6 text-[15px] font-medium text-palette-50 shadow-sm transition-colors hover:bg-palette-700"
            >Start for free</a
          >
          <a
            href="#how"
            class="inline-flex h-12 select-none items-center justify-center gap-1.5 rounded-full border border-line bg-elevated px-6 text-[15px] font-medium text-ink-1 transition-colors hover:bg-surface-2"
            >See how it works</a
          >
        </div>
        <p class="text-[13px] text-ink-3">
          Free during beta · no card needed to hear your first briefing
        </p>
      </div>
    </div>
  </div>

  <!-- product window, wide, bleeding off the bottom edge -->
  <div class="relative mx-auto w-full max-w-5xl px-4 sm:px-6" aria-hidden="true">
    <div class="hero-glow pointer-events-none absolute inset-x-0 -top-10 h-72" aria-hidden="true"></div>
    <div
      class="relative translate-y-px overflow-hidden rounded-t-2xl bg-elevated shadow-[0_-1px_0_rgba(255,255,255,0.6)_inset,0_24px_60px_-20px_color-mix(in_oklch,var(--color-palette-900)_28%,transparent)] ring-[0.5px] ring-line select-none"
    >
      <!-- window toolbar -->
      <div class="flex items-center gap-3 border-b border-line py-3 pr-4 pl-5">
        <div class="flex items-center gap-1.5">
          <div class="size-3 rounded-full bg-line"></div>
          <div class="size-3 rounded-full bg-line"></div>
          <div class="size-3 rounded-full bg-line"></div>
        </div>
        <div class="mx-auto flex items-center gap-0.5 rounded-full bg-surface-2 p-0.5">
          <div class="rounded-full bg-elevated px-3 py-1 text-[13px] font-medium text-ink-1 shadow-xs">Home</div>
          <div class="rounded-full px-3 py-1 text-[13px] font-medium text-ink-3">Briefings</div>
        </div>
        <div class="size-7 rounded-full bg-surface-2"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-[1fr_1.35fr]">
        <!-- left rail: what you follow -->
        <div class="flex flex-col gap-5 border-line p-5 sm:border-r">
          <div>
            <div class="pb-2 text-xs font-semibold tracking-wide text-ink-4 uppercase">Topics you follow</div>
            <div class="flex flex-wrap gap-1.5">
              {
                topics.map((topic) => (
                  <span class="rounded-full bg-surface-2 px-2.5 py-1 text-[13px] font-medium text-ink-2">
                    {topic}
                  </span>
                ))
              }
              <span class="rounded-full border border-dashed border-palette-300 px-2.5 py-1 text-[13px] font-medium text-ink-4">+ Add</span>
            </div>
          </div>
          <div>
            <div class="pb-2 text-xs font-semibold tracking-wide text-ink-4 uppercase">Links you added</div>
            <div class="flex flex-col gap-1">
              <div class="flex items-center gap-2.5 rounded-lg px-2 py-2 hover:bg-surface-2">
                <span class="grid size-7 flex-none place-items-center rounded-md bg-surface-2 text-ink-3">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6.75 4.75H17.25C17.8 4.75 18.25 5.2 18.25 5.75V18.25C18.25 18.8 17.8 19.25 17.25 19.25H6.75C6.2 19.25 5.75 18.8 5.75 18.25V5.75C5.75 5.2 6.2 4.75 6.75 4.75Z" /><path stroke="currentColor" stroke-linecap="round" stroke-width="1.5" d="M8.75 9.25H15.25M8.75 12.25H15.25M8.75 15.25H12.25" /></svg>
                </span>
                <span class="line-clamp-1 text-[13px] font-medium text-ink-1">The state of AI agents in 2026</span>
              </div>
              <div class="flex items-center gap-2.5 rounded-lg px-2 py-2 hover:bg-surface-2">
                <span class="grid size-7 flex-none place-items-center rounded-md bg-surface-2 text-ink-3">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.75 7.75C4.75 6.65 5.65 5.75 6.75 5.75H17.25C18.35 5.75 19.25 6.65 19.25 7.75V16.25C19.25 17.35 18.35 18.25 17.25 18.25H6.75C5.65 18.25 4.75 17.35 4.75 16.25V7.75Z" /><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5.5 6.5L12 12.25L18.5 6.5" /></svg>
                </span>
                <span class="line-clamp-1 text-[13px] font-medium text-ink-1">Why interest rates moved this week</span>
              </div>
            </div>
          </div>
        </div>

        <!-- main: today's briefing -->
        <div class="flex flex-col gap-4 p-5">
          <div class="flex items-baseline justify-between">
            <h3 class="font-display text-xl font-medium text-ink-1">Today's Briefing</h3>
            <span class="text-xs font-medium text-ink-4">Friday · 7 min</span>
          </div>

          <!-- now playing -->
          <div class="flex items-center gap-3 rounded-xl bg-surface-2 px-4 py-3">
            <button class="grid size-10 flex-none place-items-center rounded-full bg-palette-800 text-palette-50">▶</button>
            <div class="min-w-0 flex-1">
              <div class="line-clamp-1 text-[13px] font-medium text-ink-1">Now playing · 4 topics</div>
              <div class="waveform mt-1.5 flex h-5 items-end gap-[2px]">
                {
                  bars.map((b) => (
                    <span
                      class="flex-1 origin-bottom rounded-full bg-tint animate-[var(--animate-wave)]"
                      style={`height:${b.h}%;animation-delay:${b.delay}`}
                    />
                  ))
                }
              </div>
            </div>
            <span class="text-[12px] tabular-nums text-ink-3">2:14</span>
          </div>

          <!-- in this briefing -->
          <div>
            <div class="pb-2 text-xs font-semibold tracking-wide text-ink-4 uppercase">In this briefing</div>
            <div class="flex flex-col">
              {
                stories.map((s, i) => (
                  <div class={`flex items-center gap-3 py-2.5 ${i > 0 ? "border-t border-line" : ""}`}>
                    <span class="grid size-6 flex-none place-items-center rounded-full bg-surface-2 text-[11px] font-semibold text-ink-3">
                      {i + 1}
                    </span>
                    <div class="min-w-0 flex-1">
                      <div class="line-clamp-1 text-sm font-medium text-ink-1">{s.title}</div>
                      <div class="flex items-center gap-1.5 text-[12px] text-ink-4">
                        <span class="font-medium text-tint-700">{s.topic}</span>
                        <span>·</span>
                        <span>{s.source}</span>
                      </div>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const el = document.getElementById("rotating-word");
  if (el) {
    const words: string[] = JSON.parse(el.dataset.words ?? "[]");
    const reduceMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    if (words.length > 1) {
      let i = 0;

      if (reduceMotion) {
        setInterval(() => {
          i = (i + 1) % words.length;
          el.textContent = words[i];
        }, 2600);
      } else {
        const DUR = 280;
        const EASE = "cubic-bezier(0.22, 1, 0.36, 1)";

        setInterval(() => {
          el.style.transition = `transform ${DUR}ms ${EASE}`;
          el.style.transform = "translateY(-100%)";

          setTimeout(() => {
            i = (i + 1) % words.length;
            el.style.transition = "none";
            el.textContent = words[i];
            el.style.transform = "translateY(100%)";
            void el.offsetWidth;
            el.style.transition = `transform ${DUR}ms ${EASE}`;
            el.style.transform = "translateY(0)";
          }, DUR);
        }, 2600);
      }
    }
  }
</script>
