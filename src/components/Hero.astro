---
import { site } from "../config";

const queue = [
  "The state of AI agents in 2026",
  "Why interest rates moved this week",
  "A field guide to deep work",
  "Inside the new space economy",
];

// Waveform bars with varied heights + delays for an organic pulse.
const bars = Array.from({ length: 42 }, (_, i) => {
  const base = 30 + Math.round(40 * Math.abs(Math.sin(i * 1.3)));
  return { h: base, delay: `${((i % 7) * 0.12).toFixed(2)}s` };
});
---

<section class="relative overflow-hidden">
  <!-- faint dot grid backdrop -->
  <div class="dotgrid pointer-events-none absolute inset-0 opacity-60 [mask-image:radial-gradient(60%_50%_at_50%_0%,black,transparent)]"></div>

  <div class="relative mx-auto max-w-5xl px-6 pt-16 pb-12 text-center md:pt-24">
    <a
      href={site.signUp}
      class="mb-6 inline-flex items-center gap-2 rounded-full border border-neutral-200 bg-white px-3.5 py-1.5 text-[13px] font-medium text-neutral-600 shadow-sm transition hover:border-neutral-300"
    >
      <span class="size-1.5 rounded-full bg-emerald-500"></span>
      Now in early access
      <span class="text-neutral-400">→</span>
    </a>

    <h1
      class="mx-auto max-w-3xl text-[clamp(2.5rem,7vw,4.5rem)] font-semibold leading-[1.02] tracking-[-0.035em] text-neutral-900"
    >
      Save it now.<br />Hear it in the morning.
    </h1>

    <p class="mx-auto mt-6 max-w-xl text-lg text-neutral-500 md:text-xl">
      Drop in the articles you didn't get to today. Overnight, AI brews them
      into a tight podcast brief — ready before your first cup of coffee.
    </p>

    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <a
        href={site.signUp}
        class="inline-flex items-center justify-center rounded-full bg-neutral-900 px-6 py-3 text-[15px] font-medium text-white transition hover:bg-neutral-700"
        >Start your brief</a
      >
      <a
        href="#how"
        class="inline-flex items-center justify-center rounded-full border border-neutral-200 bg-white px-6 py-3 text-[15px] font-medium text-neutral-700 transition hover:bg-neutral-50"
        >See how it works</a
      >
    </div>

    <p class="mt-4 text-[13px] text-neutral-400">
      Free to start · Sign in with Google · Listen in any podcast app
    </p>

    <!-- Big centered product shot -->
    <div class="relative mx-auto mt-16 max-w-3xl" aria-hidden="true">
      <div
        class="overflow-hidden rounded-2xl border border-neutral-200 bg-white text-left shadow-[0_1px_3px_rgba(0,0,0,.04),0_24px_60px_-15px_rgba(0,0,0,.18)]"
      >
        <!-- window chrome -->
        <div class="flex items-center gap-2 border-b border-neutral-100 px-4 py-3">
          <span class="size-3 rounded-full bg-neutral-200"></span>
          <span class="size-3 rounded-full bg-neutral-200"></span>
          <span class="size-3 rounded-full bg-neutral-200"></span>
          <div
            class="mx-auto flex items-center gap-1.5 rounded-md bg-neutral-100 px-3 py-1 text-[12px] text-neutral-400"
          >
            <span class="text-neutral-300">🔒</span> app.briefly.sh
          </div>
        </div>

        <!-- app body: queue (left) + now playing (right) -->
        <div class="grid gap-0 sm:grid-cols-[1.1fr_1fr]">
          <!-- Queue -->
          <div class="border-b border-neutral-100 p-5 sm:border-b-0 sm:border-r">
            <div class="mb-3 flex items-center justify-between">
              <div class="text-[13px] font-semibold text-neutral-900">Your queue</div>
              <div class="text-[12px] text-neutral-400">4 saved today</div>
            </div>
            <ul class="space-y-1">
              {
                queue.map((item) => (
                  <li class="flex items-center gap-3 rounded-lg px-2 py-2 text-[13px] text-neutral-700 hover:bg-neutral-50">
                    <span class="size-1.5 flex-none rounded-full bg-neutral-300" />
                    <span class="truncate">{item}</span>
                  </li>
                ))
              }
            </ul>
            <div
              class="mt-3 flex items-center gap-2 rounded-lg border border-dashed border-neutral-200 px-3 py-2 text-[12px] text-neutral-400"
            >
              <span class="text-neutral-300">＋</span> Paste a link…
            </div>
          </div>

          <!-- Now playing -->
          <div class="flex flex-col justify-between bg-neutral-50/60 p-5">
            <div>
              <div class="mb-3 flex items-center gap-3">
                <div
                  class="grid size-10 place-items-center rounded-xl bg-neutral-900 text-lg text-white"
                >
                  {site.mark}
                </div>
                <div>
                  <div class="text-[13px] font-semibold text-neutral-900">Today's Brief</div>
                  <div class="text-[12px] text-neutral-400">Friday · 5 stories · 7 min</div>
                </div>
              </div>

              <div class="waveform flex h-12 items-end gap-[3px]">
                {
                  bars.map((b) => (
                    <span
                      class="flex-1 origin-bottom rounded-full bg-neutral-300 animate-[var(--animate-wave)]"
                      style={`height:${b.h}%;animation-delay:${b.delay}`}
                    />
                  ))
                }
              </div>
            </div>

            <div class="mt-4 flex items-center gap-3">
              <button class="grid size-8 place-items-center rounded-full text-neutral-400">↺</button>
              <button
                class="grid size-11 place-items-center rounded-full bg-neutral-900 text-white"
                >▶</button
              >
              <button class="grid size-8 place-items-center rounded-full text-neutral-400">↻</button>
              <div class="ml-auto text-[12px] tabular-nums text-neutral-400">2:14 / 7:02</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
