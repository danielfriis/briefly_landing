---
// Slim, centered header: just the wordmark and a single "Start for free"
// action. No nav — the page is a short single-column read top to bottom, so
// navigation would only add noise. Sits transparent over the hero, then frosts
// on scroll via [data-site-header][data-scrolled] (styles in global.css).
import { site } from "../config";
import Brand from "./Brand.astro";
---

<header
  class="sticky top-0 z-50 border-b border-transparent transition-colors duration-300"
  data-site-header
>
  <div
    class="mx-auto flex h-16 w-full max-w-2xl items-center justify-between gap-4 px-5"
  >
    <Brand />
    <a
      href={site.signUp}
      class="inline-flex h-9 select-none items-center justify-center rounded-full bg-palette-800 px-4 text-sm font-medium text-palette-50 shadow-sm transition-colors hover:bg-palette-700"
      >Start for free</a
    >
  </div>
</header>

<script>
  // Reveal the frosted bar only once scrolled — the header sits invisibly over
  // the hero, then settles into a calm strip. Frosted styles live in global.css
  // (toggling Tailwind classes from JS strings is fragile — variants get purged).
  const header = document.querySelector<HTMLElement>("[data-site-header]");
  if (header) {
    const onScroll = () => {
      header.dataset.scrolled = String(window.scrollY > 8);
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
  }
</script>
