---
import { site } from "../config";
---

<header class="sticky top-0 z-50 bg-white/80 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-5xl items-center justify-between px-6">
    <a
      href="/"
      class="inline-flex items-center gap-2 text-[15px] font-semibold tracking-tight"
    >
      <span class="text-lg" aria-hidden="true">{site.mark}</span>
      <span>{site.name}</span>
    </a>

    <nav class="flex items-center gap-1 text-sm font-medium text-neutral-500">
      <a href="#how" class="hidden rounded-lg px-3 py-2 hover:text-neutral-900 sm:inline">How it works</a>
      <a href="#features" class="hidden rounded-lg px-3 py-2 hover:text-neutral-900 sm:inline">Features</a>
      <a href={site.signIn} class="hidden rounded-lg px-3 py-2 hover:text-neutral-900 sm:inline">Sign in</a>
      <a
        href={site.signUp}
        class="ml-1 inline-flex rounded-full bg-neutral-900 px-4 py-2 text-sm font-medium text-white transition hover:bg-neutral-700"
        >Get started</a
      >
    </nav>
  </div>
</header>
