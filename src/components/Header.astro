---
import { site } from "../config";
---

<header
  class="sticky top-0 z-50 border-b border-stone-200 bg-stone-50/80 backdrop-blur-md backdrop-saturate-150"
>
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
    <a
      href="/"
      class="inline-flex items-center gap-2.5 text-lg font-bold tracking-tight"
    >
      <span class="text-[22px]" aria-hidden="true">{site.mark}</span>
      <span>{site.name}</span>
    </a>

    <nav class="flex items-center gap-5 text-[15px] font-medium text-stone-600">
      <a href="#how" class="hidden hover:text-stone-900 sm:inline">How it works</a>
      <a href="#features" class="hidden hover:text-stone-900 sm:inline">Features</a>
      <a
        href={site.signIn}
        class="hidden rounded-lg border border-stone-300 bg-white px-4 py-2 text-sm font-semibold text-stone-700 transition hover:bg-stone-100 sm:inline-flex"
        >Sign in</a
      >
      <a
        href={site.signUp}
        class="inline-flex rounded-lg bg-stone-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-stone-700"
        >Get started</a
      >
    </nav>
  </div>
</header>
